{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ember",
  "version": "0.9.0",
  "identifier": "com.shikhar.ember",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Ember",
        "width": 900,
        "height": 650,
        "minWidth": 800,
        "minHeight": 600,
        "backgroundColor": "#0B0C10",
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}